{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/estevanhernandez-stack-ed/Vibe-Lingual/schemas/audit.schema.json",
  "title": "vibe-lingual audit",
  "description": "Output of `vibe-lingual audit` — the i18n-retrofit gotcha + per-file readiness + phased-plan analysis built on a scan inventory. Read-only; consumed by localize.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "gotchas", "decisions", "readiness", "phasedPlan"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "gotchas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "file", "line", "severity", "recommendation"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "firebase-admin-ssr",
              "structural-intl",
              "timezone",
              "rtl",
              "dynamic-route-glob"
            ]
          },
          "file": { "type": ["string", "null"] },
          "line": { "type": "integer", "minimum": 0 },
          "severity": { "type": "string", "enum": ["block", "warn", "info"] },
          "recommendation": { "type": "string" }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "question", "options", "recommended"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["timezone", "dual-locale", "html-lang"]
          },
          "question": { "type": "string" },
          "options": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "recommended": { "type": "string" },
          "required": { "type": "boolean" },
          "rationale": { "type": "string" }
        }
      }
    },
    "readiness": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "status", "reason"],
        "properties": {
          "file": { "type": "string" },
          "status": { "type": "string", "enum": ["ready", "blocked"] },
          "reason": { "type": "string" },
          "siteCount": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "phasedPlan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["phase", "items"],
        "properties": {
          "phase": {
            "type": "string",
            "enum": ["extract", "wire", "translate", "wire-to-locale", "guard"]
          },
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "totalGotchas": { "type": "integer", "minimum": 0 },
        "blockers": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "infos": { "type": "integer", "minimum": 0 },
        "filesReady": { "type": "integer", "minimum": 0 },
        "filesBlocked": { "type": "integer", "minimum": 0 },
        "requiredDecisions": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
